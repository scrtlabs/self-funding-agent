# Funding Agent Configuration

# Required: Base chain RPC URL for x402 payments
FUNDING_AGENT_CHAIN_RPC_URL=https://mainnet.base.org

# Required: VM ID - automatically injected by portal when self-funding is enabled
# This is replaced with the actual VM database ID during VM creation
FUNDING_AGENT_VM_ID=$VM_ID

# Required: Base URL for devportal API (for fetching API keys and balance)
FUNDING_AGENT_BASE_URL=https://preview-aidev.scrtlabs.com

# Attestation configuration
ATTEST_HOST=localhost
ATTEST_PORT=29343

# Balance management thresholds
FUNDING_AGENT_MIN_BALANCE_USD=0.5
FUNDING_AGENT_TOPUP_USD=5

# Monitoring interval (milliseconds)
FUNDING_AGENT_CHECK_INTERVAL_MS=60000

# API server port
FUNDING_AGENT_PORT=3002

# Optional: Autonomys on-chain chat history storage
# Set to true and configure S3 values below to persist all chat requests/responses.
AUTONOMYS_CHAT_HISTORY_ENABLED=false
# AUTONOMYS_S3_ENDPOINT=https://your-autodrive-endpoint
# AUTONOMYS_S3_BUCKET=your-bucket-name
# AUTONOMYS_S3_ACCESS_KEY_ID=your-access-key-id
# AUTONOMYS_S3_SECRET_ACCESS_KEY=your-secret-access-key
# AUTONOMYS_S3_REGION=us-east-1
# AUTONOMYS_CHAT_HISTORY_PREFIX=chat-history
# AUTONOMYS_S3_FORCE_PATH_STYLE=true
# AUTONOMYS_STREAM_CAPTURE_LIMIT_BYTES=262144

# Storage paths (optional - defaults to ./data/)
# WALLET_STORAGE_PATH=./data/agent-wallet.json
# API_KEY_STORAGE_PATH=./data/api-keys.json

# VM Secret for encryption (optional - uses VM_ID if not set)
# VM_SECRET=your-secret-here
